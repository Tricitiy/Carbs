-- PERK 2: Laginator
-- Walk in place 0.7s then tp 20 studs forward, stops at obstacles
------------------------------------------------------------
local laginOnCooldown = false

local function doLaginator()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    print("[Laginator] Activated!")

    -- Just freeze position, let animation play naturally (looks like lag)
    local originalSpeed = hum.WalkSpeed
    hum.WalkSpeed = 0
    task.wait(0.7)

    -- Forward direction + raycast
    local forwardDir = hrp.CFrame.LookVector
    forwardDir = Vector3.new(forwardDir.X, 0, forwardDir.Z).Unit

    local startPos  = hrp.Position
    local targetPos = startPos + forwardDir * 20

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char}

    local result = workspace:Raycast(startPos, forwardDir * 20, rayParams)
    if result then
        local hitDist = (result.Position - startPos).Magnitude
        targetPos = startPos + forwardDir * math.max(0, hitDist - 1)
    end

    hrp.CFrame = CFrame.new(targetPos, targetPos + forwardDir)
    hum.WalkSpeed = originalSpeed
    print("[Laginator] Teleported!")
end

