local targetName         = "GunDrop"
local ACTIVATOR_KEYWORDS = {"ice", "cream", "cone"}

local function matchesAny(name, keywords)
    local lower = string.lower(name)
    for _, kw in ipairs(keywords) do
        if string.find(lower, kw) then return true end
    end
    return false
end

local function isHoldingActivator()
    local char = LocalPlayer.Character
    if not char then return false end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool and matchesAny(tool.Name, ACTIVATOR_KEYWORDS) then
        return true
    end
    return false
end

local function bringGun()
    if not isHoldingActivator() then return end

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local gun = workspace:FindFirstChild(targetName)
    if not gun or not gun:IsA("BasePart") then return end

    -- Tween it to you instead of setting CFrame directly
    TweenService:Create(
        gun,
        TweenInfo.new(0.1, Enum.EasingStyle.Linear),
        {CFrame = root.CFrame}
    ):Play()
end

task.spawn(function()
    while true do
        task.wait(0.1)
        bringGun()
    end
end)

