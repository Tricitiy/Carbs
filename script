------------------------------------------------------------
-- Aim Assist (Whitelisted + Gun holders only)
------------------------------------------------------------

local Camera = workspace.CurrentCamera

local AIM_ASSIST_RADIUS   = 95
local AIM_ASSIST_ANGLE    = 15
local AIM_ASSIST_STRENGTH = 1

local function getScreenCenter()
    return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

local function getScreenDist(targetPosition)
    local screenPos, onScreen = Camera:WorldToViewportPoint(targetPosition)
    if not onScreen then return math.huge end
    local screenVec = Vector2.new(screenPos.X, screenPos.Y)
    return (screenVec - getScreenCenter()).Magnitude
end

local function findAimAssistTarget()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local bestTarget   = nil
    local bestScreenDist = math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not isKnifeHolder(player) then continue end
        local enemyChar = player.Character
        if not enemyChar then continue end
        local enemyHrp = enemyChar:FindFirstChild("HumanoidRootPart")
        if not enemyHrp then continue end

        local worldDist = (hrp.Position - enemyHrp.Position).Magnitude
        if worldDist > AIM_ASSIST_RADIUS then continue end

        local screenDist = getScreenDist(enemyHrp.Position)
        local angleThreshold = AIM_ASSIST_ANGLE * (Camera.ViewportSize.X / 2) / 90
        if screenDist < angleThreshold and screenDist < bestScreenDist then
            bestScreenDist = screenDist
            bestTarget = enemyHrp
        end
    end

    return bestTarget
end

local function applyAimAssist()
    if not WHITELIST[LocalPlayer.Name] then return end
    if not isHoldingGun(LocalPlayer) then return end

    local target = findAimAssistTarget()
    if not target then return end

    local camCFrame    = Camera.CFrame
    local dirToTarget  = (target.Position - camCFrame.Position).Unit
    local targetCFrame = CFrame.lookAt(camCFrame.Position, camCFrame.Position + dirToTarget)

    Camera.CFrame = camCFrame:Lerp(targetCFrame, AIM_ASSIST_STRENGTH)
end

RunService.Heartbeat:Connect(applyAimAssist)

local Players      = game:GetService("Players")
