    if tick() - lastESP >= 2 then
        lastESP = tick()
        updateESP()
    end

    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            local dist = getClosestKnifeDistance()
            local inDanger = dist <= DANGER_RADIUS

            if WHITELIST[LocalPlayer.Name] then
                hum.WalkSpeed = inDanger and SPRINT_SPEED or WALK_SPEED
                hum.JumpPower = JUMP_POWER
            else
                hum.WalkSpeed = inDanger and SPRINT_SPEED or NORMAL_SPEED
            end
        end
    end
end)

