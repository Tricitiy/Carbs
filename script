------------------------------------------------------------
-- Dash logic with obstacle detection
------------------------------------------------------------
local isDashing = false

local function doDash()
    if isDashing then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    isDashing = true

    -- Lock movement during dash
    hum.WalkSpeed = 0

    -- Get the forward direction from HumanoidRootPart (ignores camera pitch)
    local forwardDir = hrp.CFrame.LookVector
    forwardDir = Vector3.new(forwardDir.X, 0, forwardDir.Z).Unit

    local startPos   = hrp.Position
    local targetPos  = startPos + forwardDir * DASH_DISTANCE

    -- Raycast forward to check for obstacles
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char}

    local result = workspace:Raycast(startPos, forwardDir * DASH_DISTANCE, rayParams)

    -- If obstacle hit, stop just before it
    if result then
        local hitDist = (result.Position - startPos).Magnitude
        targetPos = startPos + forwardDir * math.max(0, hitDist - 2)
    end

    -- Calculate duration based on distance and speed
    local actualDist = (targetPos - startPos).Magnitude
    local duration   = actualDist / DASH_SPEED

    -- Tween the dash
    local tween = TweenService:Create(
        hrp,
        TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {CFrame = CFrame.new(targetPos, targetPos + forwardDir)}
    )
    tween:Play()
    tween.Completed:Wait()

    -- Restore walkspeed
    hum.WalkSpeed = 16
    isDashing = false
end

