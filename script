-- PERK 3: Juker
-- TP 4 studs behind knife holder, facing opposite direction
------------------------------------------------------------
local jukerOnCooldown = false

local function doJuker()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local knifePlayer = getKnifeHolder()
    if not knifePlayer then
        print("[Juker] No knife holder found")
        return
    end

    local enemyChar = knifePlayer.Character
    if not enemyChar then return end
    local enemyHrp = enemyChar:FindFirstChild("HumanoidRootPart")
    if not enemyHrp then return end

    -- 30 stud radius check
    local dist = (hrp.Position - enemyHrp.Position).Magnitude
    if dist > 30 then
        print("[Juker] Knife holder too far — " .. math.floor(dist) .. " studs away")
        return
    end

    -- 4 studs behind knife holder
    local behindPos = enemyHrp.CFrame * CFrame.new(0, 0, 4)

    -- Face OPPOSITE direction of knife holder
    local oppositeDir = -enemyHrp.CFrame.LookVector
    oppositeDir = Vector3.new(oppositeDir.X, 0, oppositeDir.Z).Unit

    hrp.CFrame = CFrame.new(behindPos.Position, behindPos.Position + oppositeDir)
    print("[Juker] Teleported behind knife holder!")
end

